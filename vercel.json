{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static-build"
    },
    {
      "src": "src/test/setup.ts",
      "use": "@vercel/node-build"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "index.html"
    }
  ],
  "outputDirectory": "dist",
  "test": {
    "command": "vitest run"
  }
}